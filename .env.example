# ============================================
# GymCore environment configuration
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ============================================

# --- Application ---
DEBUG=false
DOMAIN=gym.example.com

# --- Ports ---
# Public port served by GymCore's nginx. Change it when port 80 is already
# used by another service on the same server (e.g. 8090 -> http://domain:8090).
HTTP_PORT=80
# Host loopback port of the API container (only change on conflict).
API_PORT=8000
# Generate with: openssl rand -hex 32
SECRET_KEY=
# Set true after HTTPS is enabled (also enables HSTS response header)
COOKIE_SECURE=false
# Comma-separated browser origins allowed to call the API cross-origin
# (e.g. a future SPA at https://app.example.com). Leave empty for same-origin
# only. Native mobile apps do not need this.
CORS_ORIGINS=

# --- Database ---
# Docker deployment (matches docker-compose.yml):
DATABASE_URL=postgresql+psycopg://gymcore:gymcore@db:5432/gymcore
# Bare-metal example:
# DATABASE_URL=postgresql+psycopg://gymcore:STRONG_PASSWORD@localhost:5432/gymcore

# Used by docker-compose to provision PostgreSQL:
POSTGRES_USER=gymcore
POSTGRES_PASSWORD=gymcore
POSTGRES_DB=gymcore

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# --- Bale bot ---
BALE_BOT_TOKEN=
BALE_OWNER_ID=

# --- Plan-order signup ---
# Opened as a Telegram Mini App (and a plain link on Bale) when a client
# taps «سفارش برنامه».
SIGNUP_URL=https://mahdisarmad.ir/signup/

# --- Bootstrap admin (created on first startup) ---
ADMIN_NAME=مدیر باشگاه
ADMIN_PHONE=09xxxxxxxxx
ADMIN_PASSWORD=

# --- Automated reminders (background worker) ---
# Master switch for the reminder worker.
REMINDERS_ENABLED=true
# How often the worker scans for due reminders (seconds). Default: 6 hours.
REMINDER_INTERVAL_SECONDS=21600
# Warn the client when remaining sessions drop to/below this count.
REMINDER_LOW_SESSION_THRESHOLD=2
# Nudge the client when an active course has had no attendance for this many days.
REMINDER_INACTIVE_DAYS=10
# Don't resend the same reminder for the same course within this many days.
REMINDER_RESEND_DAYS=3
