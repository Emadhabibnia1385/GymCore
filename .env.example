# ============================================================
# GymCore environment configuration (bot-first).
# Copy to .env and fill in real values.  NEVER commit .env.
# ============================================================

# --- Application ---
# Safe default bind: loopback only. The bots use long polling and need no
# public port. Change APP_PORT during install if 8815 is taken.
APP_HOST=127.0.0.1
APP_PORT=8815
# Public domain / base URL — only needed if you enable webhook mode.
APP_DOMAIN=
APP_BASE_URL=
DEBUG=false
LOG_LEVEL=INFO
TIMEZONE=Asia/Tehran
# Generate with: openssl rand -hex 32
SECRET_KEY=

# --- Database ---
# Local development (default): SQLite file.
DATABASE_URL=sqlite:///./gymcore.db
# Production example (PostgreSQL):
# DATABASE_URL=postgresql+psycopg://gymcore:STRONG_PASSWORD@localhost:5432/gymcore

# Used by docker-compose to provision PostgreSQL (optional):
POSTGRES_USER=gymcore
POSTGRES_PASSWORD=gymcore
POSTGRES_DB=gymcore

# --- Plan attachments (uploaded/stored files) ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=20

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric user IDs allowed into the admin panel.
# Example: TELEGRAM_OWNER_IDS=123456789,987654321
TELEGRAM_OWNER_IDS=
# polling (default, safe) or webhook.
TELEGRAM_BOT_MODE=polling

# --- Bale bot (Telegram-compatible Bot API) ---
BALE_BOT_TOKEN=
BALE_OWNER_IDS=
BALE_BOT_MODE=polling

# --- Plan-order signup (opened when a client taps «سفارش برنامه») ---
SIGNUP_URL=https://mahdisarmad.ir/signup/

# --- Automated reminders / notifications worker ---
REMINDERS_ENABLED=true
# How often the worker scans for due reminders (seconds). Default: 6 hours.
REMINDER_INTERVAL_SECONDS=21600
# Warn the client when remaining sessions drop to/below this count.
LOW_SESSION_THRESHOLD=2
# Nudge when an active course has had no attendance for this many days.
REMINDER_INACTIVE_DAYS=10
# Don't resend the same reminder for the same course within this many days.
REMINDER_RESEND_DAYS=3
