# ============================================
# GymCore environment configuration
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ============================================

# --- Application ---
DEBUG=false
DOMAIN=gym.example.com
# Generate with: openssl rand -hex 32
SECRET_KEY=
# Set true after HTTPS is enabled
COOKIE_SECURE=false

# --- Database ---
# Docker deployment (matches docker-compose.yml):
DATABASE_URL=postgresql+psycopg://gymcore:gymcore@db:5432/gymcore
# Bare-metal example:
# DATABASE_URL=postgresql+psycopg://gymcore:STRONG_PASSWORD@localhost:5432/gymcore

# Used by docker-compose to provision PostgreSQL:
POSTGRES_USER=gymcore
POSTGRES_PASSWORD=gymcore
POSTGRES_DB=gymcore

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# --- Bale bot ---
BALE_BOT_TOKEN=
BALE_OWNER_ID=

# --- Bootstrap admin (created on first startup) ---
ADMIN_NAME=مدیر باشگاه
ADMIN_PHONE=09xxxxxxxxx
ADMIN_PASSWORD=
