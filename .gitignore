# ============================================================
# GymCore — never commit secrets, data, or local artifacts.
# ============================================================

# --- Secrets & environment ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- Databases & data ---
*.db
*.db-journal
*.sqlite
*.sqlite3
data/
backups/

# --- Uploaded / private files ---
uploads/
media/
storage/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Logs ---
*.log
logs/

# --- IDE / editor / OS ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
